<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>InstaAuto | Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --primary: #833ab4;
            --gradient: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
            --bg: #0a0a0b;
            --card-bg: #141416;
            --text: #ffffff;
            --text-dim: #9ca3af;
            --border: #27272a;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--card-bg);
            border-right: 1px solid var(--border);
            padding: 2rem;
            display: flex;
            flex-direction: column;
        }

        .main {
            flex: 1;
            padding: 3rem;
            max-width: 1000px;
            margin: 0 auto;
            width: 100%;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            background: var(--gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 3rem;
            display: block;
            text-decoration: none;
        }

        .nav-item {
            color: var(--text-dim);
            text-decoration: none;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            margin-bottom: 0.5rem;
            transition: all 0.2s;
        }

        .nav-item:hover,
        .nav-item.active {
            background: #1f1f22;
            color: white;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
            margin-bottom: 2rem;
        }

        h2 {
            font-size: 1.5rem;
            margin-top: 0;
        }

        p {
            color: var(--text-dim);
            line-height: 1.6;
        }

        .btn {
            display: inline-block;
            padding: 0.75rem 1.5rem;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            border: none;
            transition: transform 0.2s;
            font-size: 1rem;
        }

        .btn-primary {
            background: var(--gradient);
            color: white;
        }

        .btn-secondary {
            background: #27272a;
            color: white;
        }

        .btn:hover {
            transform: translateY(-2px);
            opacity: 0.9;
        }

        textarea {
            width: 100%;
            background: #0a0a0b;
            border: 1px solid var(--border);
            border-radius: 12px;
            color: white;
            padding: 1rem;
            font-family: inherit;
            resize: vertical;
            min-height: 15rem;
            margin: 1rem 0;
            box-sizing: border-box;
        }

        .logs-container {
            background: #000;
            border-radius: 12px;
            padding: 1rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            max-height: 400px;
            overflow-y: auto;
            border: 1px solid var(--border);
        }

        .log-entry {
            padding: 0.5rem 0;
            border-bottom: 1px solid #111;
            display: flex;
        }

        .log-type {
            width: 100px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .type-incoming {
            color: #f09433;
        }

        .type-outgoing {
            color: #bc1888;
        }

        .type-info {
            color: #3b82f6;
        }

        .type-error {
            color: #ef4444;
        }

        .log-timestamp {
            color: #555;
            margin-right: 1rem;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.25rem 0.75rem;
            border-radius: 99px;
            font-size: 0.75rem;
            font-weight: 600;
            background: rgba(34, 197, 94, 0.1);
            color: #22c55e;
        }

        .hero {
            text-align: center;
            padding: 4rem 0;
        }

        .hero h1 {
            font-size: 3.5rem;
            margin-bottom: 1rem;
        }
    </style>
</head>

<body>
    <div class="sidebar">
        <a href="/" class="logo">InstaAuto</a>
        <a href="/" class="nav-item active">Dashboard</a>
        <a href="#training" class="nav-item">AI Training</a>
        <a href="#logs" class="nav-item">Activity Logs</a>
        <div style="margin-top: auto;">
            <% if (user) { %>
                <div style="font-size: 0.8rem; color: var(--text-dim); margin-bottom: 1rem;">
                    Logged in as <b>
                        <%= user.name %>
                    </b>
                </div>
                <a href="/logout" class="nav-item">Logout</a>
                <% } %>
        </div>
    </div>

    <div class="main">
        <% if (!user) { %>
            <div class="hero">
                <h1>Automate your <br><span
                        style="background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Instagram
                        DMs</span></h1>
                <p>Connect your business account and let AI handle the rest. <br>Trained on your brand's unique voice.
                </p>
                <div style="margin-top: 2rem;">
                    <a href="/auth/instagram" class="btn btn-primary">Connect with Instagram</a>
                </div>
            </div>
            <% } else { %>
                <div class="card">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <h2>Active Agent</h2>
                        <span class="status-badge">● Live</span>
                    </div>
                    <p>Your AI agent is currently monitoring <b>
                            <%= user.instagram_business_id %>
                        </b>. It will automatically reply to incoming messages using your training data.</p>
                </div>

                <div id="training" class="card">
                    <h2>AI Training Data</h2>
                    <p>Paste conversation snippets, FAQs, or brand guidelines. The more context you provide, the better
                        the AI sounds like you.</p>
                    <form action="/save-training" method="POST">
                        <textarea name="content" placeholder="E.g.
Q: What is your pricing?
A: Our basic plan starts at $29/mo.

Q: How do I contact support?
A: Email us at support@instaauto.com."><%= trainingData %></textarea>
                        <button type="submit" class="btn btn-primary">Update Training</button>
                    </form>
                </div>

                <div id="logs" class="card">
                    <h2>Recent Activity</h2>
                    <p>Real-time view of your agent's interactions.</p>
                    <div class="logs-container">
                        <% if (logs.length===0) { %>
                            <div style="color: #444; text-align: center; padding: 2rem;">No activity yet. Send a DM to
                                test!</div>
                            <% } else { %>
                                <% logs.forEach(log=> { %>
                                    <div class="log-entry">
                                        <span class="log-timestamp">[<%= new Date(log.timestamp).toLocaleTimeString() %>
                                                ]</span>
                                        <span
                                            class="log-type type-<%= log.type === 'info' || log.type === 'error' ? log.type : (log.type === 'outgoing' ? 'outgoing' : 'incoming') %>">
                                            <%= log.type %>
                                        </span>
                                        <span class="log-msg">
                                            <%= log.message %>
                                        </span>
                                    </div>
                                    <% }) %>
                                        <% } %>
                    </div>
                </div>
                <% } %>
    </div>
</body>

</html>